{
  "rules": {
    ".read": false,
    ".write": false,
    "lobby": {
      "waiting": {
        ".read": true,
        ".write": true,
        ".validate": "newData.hasChildren(['peerId', 'ts']) || !newData.exists()",
        "peerId": { ".validate": "newData.isString() && newData.val().length < 80" },
        "ts":     { ".validate": "newData.isNumber()" },
        "$other": { ".validate": false }
      }
    }
  }
}
